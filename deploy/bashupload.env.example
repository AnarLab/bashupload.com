# Copy to /etc/bashupload.env or .env and point systemd EnvironmentFile at it.
BASE_URL=https://upload.example.com
UPLOAD_DIR=/var/lib/bashupload/uploads
DB_PATH=/var/lib/bashupload/uploads.db
TTL_SECONDS=259200
MAX_DOWNLOADS=1
# 0 = unlimited size (nginx client_max_body_size still applies)
MAX_UPLOAD_BYTES=0
